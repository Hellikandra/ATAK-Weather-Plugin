      { "key": "freezing_level_height",    "label": "Freezing Level Height (m)",     "defaultOn": false },
      { "key": "uv_index",                 "label": "UV Index",                      "defaultOn": false },
      { "key": "is_day",                   "label": "Is Day (1/0)",                  "defaultOn": false }
