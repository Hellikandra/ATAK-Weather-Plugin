  "apiBaseUrl":     "https://api.open-meteo.com/v1/forecast",
  "requiresApiKey": false,
  "description":    "Free global forecast — no API key. Up to 16 days, 1-hour resolution. Multi-model blend (GFS, ICON, ECMWF, etc.).",

  "parameters": {
    "hourly": [
      { "key": "temperature_2m",            "label": "Temperature 2m (°C)",          "defaultOn": true  },
      { "key": "relative_humidity_2m",      "label": "Relative Humidity 2m (%)",      "defaultOn": true  },
      { "key": "dew_point_2m",             "label": "Dew Point 2m (°C)",            "defaultOn": false },
      { "key": "apparent_temperature",      "label": "Apparent Temperature (°C)",     "defaultOn": true  },
      { "key": "precipitation_probability", "label": "Precip. Probability (%)",       "defaultOn": true  },
      { "key": "precipitation",            "label": "Precipitation (mm)",            "defaultOn": false },
      { "key": "rain",                     "label": "Rain (mm)",                     "defaultOn": false },
      { "key": "snowfall",                 "label": "Snowfall (cm)",                 "defaultOn": false },
      { "key": "snow_depth",               "label": "Snow Depth (m)",                "defaultOn": false },
      { "key": "weather_code",             "label": "WMO Weather Code",              "defaultOn": true  },
      { "key": "pressure_msl",             "label": "Sea-Level Pressure (hPa)",      "defaultOn": false },
