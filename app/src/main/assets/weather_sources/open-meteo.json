      { "key": "apparent_temperature_max",      "label": "Max Apparent Temp (°C)",          "defaultOn": false },
      { "key": "apparent_temperature_min",      "label": "Min Apparent Temp (°C)",          "defaultOn": false },
      { "key": "precipitation_sum",             "label": "Precipitation Sum (mm)",          "defaultOn": true  },
