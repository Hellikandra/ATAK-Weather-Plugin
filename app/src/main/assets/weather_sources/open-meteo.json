      { "key": "wind_speed_10m_max",            "label": "Max Wind Speed 10m (m/s)",        "defaultOn": true  },
      { "key": "wind_gusts_10m_max",            "label": "Max Wind Gusts 10m (m/s)",        "defaultOn": false },
      { "key": "wind_direction_10m_dominant",   "label": "Dominant Wind Direction (°)",     "defaultOn": true  },
      { "key": "uv_index_max",                  "label": "UV Index Max",                    "defaultOn": false },
      { "key": "sunrise",                       "label": "Sunrise (ISO8601)",               "defaultOn": false },
