    "current": [
      { "key": "temperature_2m",        "label": "Temperature 2m (°C)",    "defaultOn": true  },
      { "key": "relative_humidity_2m",  "label": "Relative Humidity (%)",   "defaultOn": true  },
      { "key": "apparent_temperature",  "label": "Apparent Temperature (°C)","defaultOn": true  },
      { "key": "weather_code",         "label": "WMO Weather Code",         "defaultOn": true  },
      { "key": "surface_pressure",     "label": "Surface Pressure (hPa)",   "defaultOn": true  },
      { "key": "wind_speed_10m",       "label": "Wind Speed 10m (m/s)",     "defaultOn": true  },
      { "key": "wind_direction_10m",   "label": "Wind Direction 10m (°)",   "defaultOn": true  },
      { "key": "wind_gusts_10m",       "label": "Wind Gusts 10m (m/s)",     "defaultOn": false },
      { "key": "precipitation",        "label": "Precipitation (mm)",       "defaultOn": false },
      { "key": "cloud_cover",          "label": "Cloud Cover (%)",          "defaultOn": false },
      { "key": "visibility",           "label": "Visibility (m)",           "defaultOn": true  },
      { "key": "is_day",               "label": "Is Day (1/0)",             "defaultOn": false }
