<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_config.xml — Tab 3 "CONF": Map Overlay + API Source + Parameters

    New: API Source Spinner at top — selects the weather data provider.
    New entries in IWeatherRemoteSource let future providers register themselves.
    The Spinner is wired to WeatherSourceManager (SharedPrefs key "wx_source_id").
-->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/subTabWidget3"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Source/provider selection is in the PARM tab. -->

    <!-- ══ SECTION 1: MAP MARKER ════════════════════════════════════ -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_section_title"
      android:textSize="13sp"
      android:textStyle="bold"
      android:layout_marginBottom="4dp"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_pick_description"
      android:textSize="11sp"
      android:layout_marginBottom="10dp"/>

    <TextView
      android:id="@+id/textview_pick_hint"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_pick_hint"
      android:textSize="11sp"
      android:textStyle="bold"
      android:textColor="#FFFFA500"
      android:background="#33FFA500"
      android:padding="8dp"
      android:layout_marginBottom="8dp"
      android:visibility="gone"/>

    <Button android:id="@+id/btn_drop_weather_marker"
      style="@style/darkButton" android:layout_width="match_parent"
      android:layout_height="48dp" android:text="@string/map_btn_pick_and_drop"
      android:textSize="12sp" android:layout_marginBottom="6dp"/>

    <Button android:id="@+id/btn_share_marker"
      style="@style/darkButton" android:layout_width="match_parent"
      android:layout_height="48dp" android:text="@string/map_btn_share_marker"
      android:textSize="12sp" android:layout_marginBottom="6dp"/>

    <Button android:id="@+id/btn_remove_all_markers"
      style="@style/darkButton" android:layout_width="match_parent"
      android:layout_height="48dp" android:text="@string/map_btn_remove_markers"
      android:textSize="12sp" android:layout_marginBottom="10dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/map_marker_status_label" android:textSize="11sp"
      android:textStyle="bold" android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/textview_marker_status"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/map_marker_none_placed" android:textSize="11sp"
      android:fontFamily="monospace" android:layout_marginBottom="12dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- ══ SECTION 2: RADAR OVERLAY ═══════════════════════════════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_section_title" android:textSize="13sp"
      android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_section_desc" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="4dp"/>

    <!-- Radar source selector -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="6dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/radar_source_label" android:textSize="11sp"
        android:layout_marginEnd="8dp"/>
      <Spinner android:id="@+id/spinner_radar_source" android:spinnerMode="dropdown"
        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"/>
      <Button android:id="@+id/btn_refresh_radar_sources" style="@style/darkButton"
        android:layout_width="44dp" android:layout_height="44dp"
        android:text="⟳" android:textSize="16sp" android:layout_marginStart="4dp"
        android:padding="0dp"/>
    </LinearLayout>

    <TextView android:id="@+id/textview_radar_source_info"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="" android:textSize="9sp" android:alpha="0.65"
      android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

    <!-- 2D-only notice -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_2d_only_notice" android:textSize="9sp"
      android:textColor="#FFFF9800" android:layout_marginBottom="8dp"
      android:drawablePadding="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="8dp">
      <Button android:id="@+id/btn_radar_show" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
        android:text="@string/radar_btn_show" android:textSize="11sp"
        android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/btn_radar_hide" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
        android:text="@string/radar_btn_hide" android:textSize="11sp"/>
    </LinearLayout>

    <!-- Frame scrubber -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/radar_frame_label"
        android:textSize="11sp"/>
      <TextView android:id="@+id/textview_radar_time" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="—" android:textSize="11sp"
        android:textStyle="bold" android:fontFamily="monospace"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_radar_frame" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="0" android:progress="0"
      android:layout_marginBottom="8dp"/>

    <!-- Opacity -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/radar_opacity_label"
        android:textSize="11sp"/>
      <TextView android:id="@+id/textview_radar_opacity" android:layout_width="44dp"
        android:layout_height="wrap_content" android:text="60%" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_radar_opacity" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="100" android:progress="60"
      android:layout_marginBottom="4dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#33FFFFFF" android:layout_marginBottom="8dp"/>

    <!-- ══ SECTION 2b: RADAR APPEARANCE (Sprint 1.1c) ════════════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_color_section_title" android:textSize="12sp"
      android:textStyle="bold" android:layout_marginBottom="2dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_color_section_desc" android:textSize="9sp"
      android:alpha="0.65" android:layout_marginBottom="6dp"/>

    <!-- Saturation -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/radar_saturation_label"
        android:textSize="11sp"/>
      <TextView android:id="@+id/textview_radar_saturation" android:layout_width="44dp"
        android:layout_height="wrap_content" android:text="100%" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_radar_saturation" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="100" android:progress="100"
      android:layout_marginBottom="4dp"/>

    <!-- Brightness (value) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/radar_value_label"
        android:textSize="11sp"/>
      <TextView android:id="@+id/textview_radar_value" android:layout_width="44dp"
        android:layout_height="wrap_content" android:text="100%" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_radar_value" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="100" android:progress="100"
      android:layout_marginBottom="4dp"/>

    <!-- Intensity -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/radar_intensity_label"
        android:textSize="11sp"/>
      <TextView android:id="@+id/textview_radar_intensity" android:layout_width="44dp"
        android:layout_height="wrap_content" android:text="100%" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_radar_intensity" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="100" android:progress="100"
      android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/textview_radar_status" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:text="@string/radar_status_idle"
      android:textSize="10sp" android:textStyle="italic" android:alpha="0.7"
      android:layout_marginBottom="4dp"/>

    <!-- Tile diagnostics: zoom, tile count, coverage area, centre coords -->
    <TextView android:id="@+id/textview_radar_diagnostics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text=""
      android:textSize="9sp"
      android:fontFamily="monospace"
      android:alpha="0.65"
      android:layout_marginBottom="6dp"/>

    <!-- Re-center: fetch tiles for the current map viewport -->
    <Button android:id="@+id/btn_radar_recenter"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="36dp"
      android:text="@string/radar_btn_recenter"
      android:textSize="11sp"
      android:layout_marginBottom="10dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="10dp"/>

    <!-- ══ SECTION 3: RADAR TILE CACHE ═══════════════════════════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_cache_section_title" android:textSize="13sp"
      android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_cache_section_desc" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="6dp"/>

    <TextView android:id="@+id/textview_radar_cache_size"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/radar_cache_disabled" android:textSize="11sp"
      android:fontFamily="monospace" android:layout_marginBottom="6dp"/>

    <Button android:id="@+id/btn_radar_clear_cache"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="36dp"
      android:text="@string/radar_cache_clear_btn"
      android:textSize="11sp"
      android:layout_marginBottom="10dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- ══ SECTION 4: WEATHER HEATMAP (Sprint 11) ════════════════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/heatmap_section_title" android:textSize="13sp"
      android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/heatmap_section_desc" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="6dp"/>

    <!-- Parameter selector + toggle -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="6dp">
      <Spinner android:id="@+id/heatmap_param_spinner" android:spinnerMode="dropdown"
        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"/>
      <Button android:id="@+id/btn_heatmap_toggle" style="@style/darkButton"
        android:layout_width="72dp" android:layout_height="44dp"
        android:text="@string/heatmap_btn_toggle_off" android:textSize="12sp"
        android:layout_marginStart="6dp"/>
    </LinearLayout>

    <!-- Opacity -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/heatmap_opacity_label"
        android:textSize="11sp"/>
      <TextView android:id="@+id/heatmap_opacity_label" android:layout_width="44dp"
        android:layout_height="wrap_content" android:text="60%" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/heatmap_opacity_bar" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="100" android:progress="60"
      android:layout_marginBottom="6dp"/>

    <!-- Playback controls -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="4dp">
      <Button android:id="@+id/btn_heatmap_prev" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
        android:text="\u25C0" android:textSize="14sp" android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/btn_heatmap_play" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
        android:text="\u25B6" android:textSize="14sp" android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/btn_heatmap_next" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
        android:text="\u25B6\u25B6" android:textSize="14sp"/>
    </LinearLayout>

    <!-- Time scrubber -->
    <SeekBar android:id="@+id/heatmap_time_bar" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="47" android:progress="0"
      android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/heatmap_time_label" android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/heatmap_time_label_default" android:textSize="11sp"
      android:textStyle="bold" android:fontFamily="monospace"
      android:gravity="center" android:layout_marginBottom="4dp"/>

    <!-- Accuracy badge -->
    <TextView android:id="@+id/heatmap_accuracy_badge" android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/heatmap_accuracy_badge" android:textSize="9sp"
      android:fontFamily="monospace" android:alpha="0.65"
      android:layout_marginBottom="10dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- ══ SECTION 5: AVIATION OVERLAYS (Sprint 14 — S14.1) ══════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/sigmet_section_title" android:textSize="13sp"
      android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="6dp">
      <CheckBox android:id="@+id/cb_sigmet_overlay"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/sigmet_overlay"
        android:textSize="11sp"/>
      <Button android:id="@+id/btn_refresh_sigmets" style="@style/darkButton"
        android:layout_width="80dp" android:layout_height="36dp"
        android:text="@string/sigmet_refresh" android:textSize="11sp"/>
    </LinearLayout>

    <TextView android:id="@+id/sigmet_status_text"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/sigmet_status_off" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="8dp"/>

    <!-- ══ SECTION 6: LIGHTNING (Sprint 14 — S14.2) ══════════════════ -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="4dp">
      <CheckBox android:id="@+id/cb_lightning_overlay"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="@string/lightning_overlay"
        android:textSize="11sp"/>
      <Spinner android:id="@+id/lightning_radius_spinner"
        android:layout_width="100dp" android:layout_height="36dp"
        android:spinnerMode="dropdown"/>
    </LinearLayout>

    <TextView android:id="@+id/lightning_status_text"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/lightning_status_off" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/lightning_count_text"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:visibility="gone"
      android:text="@string/lightning_count_default" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="10dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="12dp"/>

    <!-- ══ SECTION 7: CBRN DISPERSION (Sprint 14 — S14.3 R&D) ═══════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/cbrn_title" android:textSize="13sp"
      android:textStyle="bold" android:layout_marginBottom="2dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/cbrn_disclaimer"
      android:textColor="#FFf85149" android:textSize="10sp"
      android:layout_marginBottom="6dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="6dp">
      <Button android:id="@+id/btn_cbrn_place" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
        android:text="@string/cbrn_place_release" android:textSize="11sp"
        android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/btn_cbrn_clear" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
        android:text="@string/cbrn_clear" android:textSize="11sp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="6dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/cbrn_distance_label" android:textSize="11sp"
        android:layout_marginEnd="8dp"/>
      <Spinner android:id="@+id/cbrn_distance_spinner"
        android:layout_width="0dp" android:layout_height="36dp"
        android:layout_weight="1" android:spinnerMode="dropdown"/>
    </LinearLayout>

    <TextView android:id="@+id/cbrn_stability_text"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/cbrn_stability_default" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="2dp"/>

    <TextView android:id="@+id/cbrn_wind_text"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/cbrn_wind_default" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="10dp"/>

  </LinearLayout>
</ScrollView>
