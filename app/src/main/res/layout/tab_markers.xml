<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_markers.xml — Sprint 17 (S17.1): Markers View

    Dedicated marker management tab: marker type selection, drop/share/remove
    actions, active markers list, and collapsible route weather section.
-->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- ══ SECTION 1: MARKER TYPE SELECTOR ═══════════════════════════ -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Marker Type"
      android:textSize="12sp"
      android:textStyle="bold"
      android:layout_marginBottom="4dp"/>

    <Spinner
      android:id="@+id/marker_type_spinner"
      android:layout_width="match_parent"
      android:layout_height="44dp"
      android:spinnerMode="dropdown"
      android:background="@drawable/image_view_bg"
      android:layout_marginBottom="8dp"/>

    <!-- ══ SECTION 2: ACTION BUTTONS ═════════════════════════════════ -->
    <Button
      android:id="@+id/btn_drop_marker"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="40dp"
      android:text="\uD83D\uDCCD Drop Marker on Map"
      android:textSize="11sp"
      android:layout_marginBottom="4dp"/>

    <Button
      android:id="@+id/btn_share_marker"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="40dp"
      android:text="\uD83D\uDCE4 Share Selected Marker"
      android:textSize="11sp"
      android:layout_marginBottom="4dp"/>

    <Button
      android:id="@+id/btn_remove_all_markers"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="40dp"
      android:text="\uD83D\uDDD1 Remove All Markers"
      android:textSize="11sp"
      android:layout_marginBottom="10dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="#30363d"
      android:layout_marginBottom="10dp"/>

    <!-- ══ SECTION 3: ACTIVE MARKERS LIST ════════════════════════════ -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Active Markers"
      android:textSize="12sp"
      android:textStyle="bold"
      android:layout_marginBottom="2dp"/>

    <TextView
      android:id="@+id/marker_count_label"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="0 markers"
      android:textSize="10sp"
      android:alpha="0.7"
      android:layout_marginBottom="4dp"/>

    <ListView
      android:id="@+id/marker_list"
      android:layout_width="match_parent"
      android:layout_height="200dp"
      android:divider="#30363d"
      android:dividerHeight="1dp"
      android:background="@drawable/image_view_bg"
      android:layout_marginBottom="10dp"
      android:nestedScrollingEnabled="true"
      android:scrollbars="vertical"
      android:fadingEdge="vertical"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="#30363d"
      android:layout_marginBottom="10dp"/>

    <!-- ══ SECTION 4: ROUTE WEATHER (collapsible) ════════════════════ -->
    <LinearLayout
      android:id="@+id/section_route_weather"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <TextView
        android:id="@+id/section_route_weather_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\u25B8 Route Weather"
        android:textSize="12sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/image_view_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

      <LinearLayout
        android:id="@+id/route_weather_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="8dp">

        <Button
          android:id="@+id/btn_select_route"
          style="@style/darkButton"
          android:layout_width="match_parent"
          android:layout_height="40dp"
          android:text="Select ATAK Route"
          android:textSize="11sp"
          android:layout_marginBottom="4dp"/>

        <Button
          android:id="@+id/btn_fetch_route_weather"
          style="@style/darkButton"
          android:layout_width="match_parent"
          android:layout_height="40dp"
          android:text="Fetch Weather Along Route"
          android:textSize="11sp"
          android:layout_marginBottom="6dp"/>

        <ListView
          android:id="@+id/route_weather_results"
          android:layout_width="match_parent"
          android:layout_height="150dp"
          android:divider="#30363d"
          android:dividerHeight="1dp"
          android:background="@drawable/image_view_bg"
          android:nestedScrollingEnabled="true"
          android:layout_marginBottom="6dp"/>

        <!-- Route weather chart (wind + precipitation) -->
        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="Route Weather Chart"
          android:textSize="10sp"
          android:textStyle="bold"
          android:alpha="0.8"
          android:layout_marginBottom="2dp"/>

        <FrameLayout
          android:id="@+id/route_weather_chart_frame"
          android:layout_width="match_parent"
          android:layout_height="160dp"
          android:background="@drawable/image_view_bg"
          android:layout_marginBottom="4dp"/>

      </LinearLayout>
    </LinearLayout>

  </LinearLayout>
</ScrollView>
