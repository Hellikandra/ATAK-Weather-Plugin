<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_wind_profile.xml
    Tab 3 — Multi-altitude wind profile display.
-->
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/subTabWidget3"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="8dp">

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="@string/wind_profile_title"
    android:textSize="14sp"
    android:textStyle="bold"
    android:layout_marginBottom="8dp" />

  <Button
    android:id="@+id/wind_update_information_button"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="@string/wind_request_button" />

  <!-- Monospaced font for the altitude table -->
  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp">

    <TextView
      android:id="@+id/textview_tab3_waiting_json_data"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:fontFamily="monospace"
      android:textSize="12sp"
      android:padding="4dp" />

  </ScrollView>

</LinearLayout>
