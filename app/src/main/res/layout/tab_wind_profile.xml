<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_wind_profile.xml — Tab 2 "WIND"

    Sections (top→bottom):
      1. Header: title + [Map Centre] [Tap Map]
      2. Source spinner
      3. Slot tab strip
      4. WindChartView (altitude barbs — low→high, bottom→top)
      5. Wind Effect controls: hour + altitude layers + range + height + Draw/Clear
      ── divider ──
      6. Wind Rose
      ── divider ──
      7. Wind Profile detail (text table)
-->
<androidx.core.widget.NestedScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/subTabWidget2"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 1. HEADER                                                    -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:text="@string/wind_profile_title" android:textSize="13sp" android:textStyle="bold"/>
      <Button android:id="@+id/btn_wind_map_centre" style="@style/darkButton"
        android:layout_width="88dp" android:layout_height="34dp"
        android:text="Map Centre" android:textSize="9sp"
        android:paddingStart="6dp" android:paddingEnd="6dp"
        android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/wind_update_information_button" style="@style/darkButton"
        android:layout_width="88dp" android:layout_height="34dp"
        android:text="Tap Map" android:textSize="9sp"
        android:paddingStart="6dp" android:paddingEnd="6dp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 2. SOURCE SPINNER                                            -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout android:id="@+id/wind_source_row"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="4dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/wind_source_label" android:textSize="10sp"
        android:alpha="0.85" android:layout_marginEnd="6dp"/>
      <Spinner android:id="@+id/spinner_wind_source"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:minHeight="44dp"
        android:spinnerMode="dropdown"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 3. SLOT TAB STRIP                                            -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:scrollbars="none" android:layout_marginBottom="4dp">
      <LinearLayout android:id="@+id/wind_slot_tab_strip"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:visibility="gone"/>
    </HorizontalScrollView>

    <TextView
      android:id="@+id/textview_wind_source_badge"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="" android:textSize="10sp" android:textStyle="italic"
      android:alpha="0.75" android:paddingStart="4dp" android:paddingBottom="4dp"
      android:visibility="gone"/>

    <TextView android:id="@+id/textview_wind_empty"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/wind_no_slots_hint"
      android:textSize="11sp" android:textStyle="italic"
      android:alpha="0.6" android:gravity="center"
      android:paddingTop="24dp" android:paddingBottom="24dp"
      android:visibility="visible"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 4. WIND CHART                                                -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <FrameLayout android:id="@+id/wind_chart_frame"
      android:layout_width="match_parent" android:layout_height="224dp"
      android:background="@drawable/image_view_bg"
      android:layout_marginBottom="6dp"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 5. WIND EFFECT CONTROLS                                      -->
    <!--    Groups all 3 seekbars + altitude toggles + draw/clear     -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/wind_effect_section_title" android:textSize="12sp"
      android:textStyle="bold" android:layout_marginBottom="2dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="@string/wind_effect_description" android:textSize="10sp"
      android:alpha="0.7" android:layout_marginBottom="6dp"/>

    <!-- Hour seekbar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/wind_hour_label" android:textSize="10sp" android:layout_marginEnd="6dp"/>
      <SeekBar android:id="@+id/wind_seekbar" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1" android:max="167"/>
    </LinearLayout>

    <!-- Altitude layers -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:layout_marginBottom="6dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Altitude Layers" android:textSize="10sp" android:textStyle="bold"
        android:alpha="0.8" android:layout_marginBottom="3dp"/>
      <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none">
        <LinearLayout android:id="@+id/wind_altitude_toggle_strip"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:orientation="horizontal" android:gravity="center_vertical"/>
      </HorizontalScrollView>
    </LinearLayout>

    <!-- Range slider -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:text="@string/wind_effect_range_label" android:textSize="11sp"/>
      <TextView android:id="@+id/textview_wind_range_value" android:layout_width="60dp"
        android:layout_height="wrap_content" android:text="2.0 km" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_wind_range" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="19" android:progress="3"
      android:layout_marginBottom="6dp"/>

    <!-- Height slider -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:text="@string/wind_effect_height_label" android:textSize="11sp"/>
      <TextView android:id="@+id/textview_wind_height_value" android:layout_width="60dp"
        android:layout_height="wrap_content" android:text="500 m" android:textSize="11sp"
        android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <SeekBar android:id="@+id/seekbar_wind_height" android:layout_width="match_parent"
      android:layout_height="wrap_content" android:max="38" android:progress="9"
      android:layout_marginBottom="8dp"/>

    <!-- Draw + Clear -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="6dp">
      <Button android:id="@+id/btn_draw_wind_effect" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="3"
        android:text="@string/wind_effect_draw_btn" android:textSize="11sp" android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/btn_clear_wind_effect" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
        android:text="@string/wind_effect_clear_btn" android:textSize="11sp"/>
    </LinearLayout>

    <!-- ── Divider ────────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="8dp"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 6. WIND ROSE                                                 -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:layout_marginBottom="4dp">
      <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:text="Wind Rose" android:textSize="12sp" android:textStyle="bold"/>
      <Button android:id="@+id/btn_wind_rose_help" style="@style/darkButton"
        android:layout_width="32dp" android:layout_height="32dp"
        android:text="?" android:textSize="14sp"/>
    </LinearLayout>

    <TextView android:id="@+id/wind_rose_data_label"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="Surface wind (10m) from hourly forecast"
      android:textSize="9sp" android:textStyle="italic" android:alpha="0.7"
      android:paddingStart="4dp" android:layout_marginBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginBottom="4dp">
      <Button android:id="@+id/wind_rose_24h" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
        android:text="24h" android:textSize="10sp" android:layout_marginEnd="3dp"/>
      <Button android:id="@+id/wind_rose_48h" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
        android:text="48h" android:textSize="10sp" android:layout_marginEnd="3dp"/>
      <Button android:id="@+id/wind_rose_forecast" style="@style/darkButton"
        android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
        android:text="Forecast" android:textSize="10sp"/>
    </LinearLayout>

    <FrameLayout android:id="@+id/wind_rose_frame"
      android:layout_width="match_parent" android:layout_height="280dp"
      android:background="@drawable/image_view_bg"
      android:layout_marginBottom="4dp"/>

    <TextView android:id="@+id/wind_rose_summary"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="" android:textSize="10sp" android:fontFamily="monospace"
      android:gravity="center" android:alpha="0.85"
      android:layout_marginBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center"
      android:layout_marginBottom="8dp">
      <Button android:id="@+id/wind_rose_zoom_out" style="@style/darkButton"
        android:layout_width="32dp" android:layout_height="32dp"
        android:text="-" android:textSize="16sp"/>
      <Button android:id="@+id/wind_rose_zoom_in" style="@style/darkButton"
        android:layout_width="32dp" android:layout_height="32dp"
        android:text="+" android:textSize="16sp"
        android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- ── Divider ────────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#55FFFFFF" android:layout_marginBottom="8dp"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- 7. WIND PROFILE DETAIL (text table at end)                   -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="Wind Profile Detail" android:textSize="12sp"
      android:textStyle="bold" android:layout_marginBottom="4dp"/>

    <TextView android:id="@+id/textview_tab3_waiting_json_data"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:fontFamily="monospace" android:textSize="11sp" android:padding="4dp"
      android:background="@drawable/image_view_bg"
      android:layout_marginBottom="8dp"/>

    <!-- Drop marker button removed — use Markers tab instead -->
    <!-- Hidden views kept for backward compat (coordinator still references them) -->
    <TextView android:id="@+id/textview_wind_marker_coord"
      android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

  </LinearLayout>
</androidx.core.widget.NestedScrollView>
