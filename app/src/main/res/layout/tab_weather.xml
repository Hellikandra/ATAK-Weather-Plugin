<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_weather.xml — Tab 1 "WTHR": Forecast + Chart (merged)

    Changes vs sprint-12 version:
    ① Refresh button + location info are on ONE row (button left, info right)
    ② chart_frame has an invisible transparent SeekBar overlay (id=seekbar_chart_overlay)
       that mirrors the main seekBar — dragging directly on the chart moves the cursor
-->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/subTabWidget1"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- ── ① Compact header row: [🔄 icon btn] [date / town / coords] ──────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="4dp">

      <!-- Refresh button — compact square -->
      <ImageButton
        android:id="@+id/imageButton"
        style="@style/darkButton"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@drawable/ic_launcher"
        android:contentDescription="@string/refresh_weather"
        android:layout_marginEnd="8dp"/>

      <!-- Location info block -->
      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:id="@+id/textView_date"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/wait"
          android:textSize="10sp"/>

        <TextView
          android:id="@+id/textView_town"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/city_town"
          android:textSize="12sp"
          android:textStyle="bold"/>

        <TextView
          android:id="@+id/textview_coords"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text=""
          android:textSize="9sp"
          android:alpha="0.7"/>

        <TextView
          android:id="@+id/textview_source_label"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text=""
          android:textSize="9sp"
          android:textStyle="italic"
          android:visibility="gone"/>

        <TextView
          android:id="@+id/textview_cache_badge"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text=""
          android:textSize="9sp"
          android:textColor="#FFCC44"
          android:textStyle="italic"
          android:visibility="gone"/>
      </LinearLayout>
    </LinearLayout>

    <!-- ── Icon + temperature row ─────────────────────────────────────────── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="4dp">

      <ImageView
        android:id="@+id/image"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/wc_00d"
        android:background="@drawable/image_view_bg"
        android:contentDescription="@string/weather_icon_desc"/>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
          android:id="@+id/textview_weather"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/weather"
          android:textSize="13sp"
          android:textStyle="bold"/>

        <TextView
          android:id="@+id/textview_airT"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="— / —°C"
          android:textSize="17sp"
          android:textStyle="bold"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/real_feel" android:textSize="11sp"/>
          <TextView android:id="@+id/textview_airTrf" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—°C" android:textSize="11sp" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/visibility_label" android:textSize="11sp"/>
          <TextView android:id="@+id/textview_visibility" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— m" android:textSize="11sp" android:layout_marginStart="4dp"/>
        </LinearLayout>
      </LinearLayout>

      <!-- Compact detail column (right side of icon row) -->
      <TableLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp">
        <TableRow>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/humidity_label" android:textStyle="bold" android:paddingEnd="6dp" android:textSize="10sp"/>
          <TextView android:id="@+id/textview_humidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— %" android:textSize="10sp"/>
        </TableRow>
        <TableRow>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pressure_label" android:textStyle="bold" android:paddingEnd="6dp" android:textSize="10sp"/>
          <TextView android:id="@+id/textview_pressure" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— hPa" android:textSize="10sp"/>
        </TableRow>
        <TableRow>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/wind_label" android:textStyle="bold" android:paddingEnd="6dp" android:textSize="10sp"/>
          <TextView android:id="@+id/textview_wind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— m/s" android:textSize="10sp"/>
        </TableRow>
        <TableRow>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/precipitation_label" android:textStyle="bold" android:paddingEnd="6dp" android:textSize="10sp"/>
          <TextView android:id="@+id/textview_precipitation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nopre" android:textSize="10sp"/>
        </TableRow>
      </TableLayout>
    </LinearLayout>

    <!-- ── Chart section ──────────────────────────────────────────────────── -->
    <!-- Outer seekBar removed: the chart_frame carries seekbar_chart_overlay  -->
    <!-- directly inside its FrameLayout, so scrubbing is done via the chart.  -->
    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="#33FFFFFF"
      android:layout_marginBottom="4dp"/>

    <!-- Chart header: location + timestamp -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="3dp">

      <TextView
        android:id="@+id/chart_location_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="—"
        android:textSize="10sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="1"/>

      <TextView
        android:id="@+id/chart_timestamp_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="9sp"
        android:textColor="#FFCC44"
        android:textStyle="italic"/>
    </LinearLayout>

    <!-- Legend toggle chips -->
    <HorizontalScrollView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginBottom="3dp">
      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <Button android:id="@+id/chart_toggle_temp"
          style="@style/darkButton" android:layout_width="wrap_content" android:layout_height="34dp"
          android:text="@string/chart_legend_temp" android:textSize="11sp"
          android:paddingStart="10dp" android:paddingEnd="10dp"
          android:backgroundTint="#FF5C8A" android:layout_marginEnd="5dp"/>
        <Button android:id="@+id/chart_toggle_humidity"
          style="@style/darkButton" android:layout_width="wrap_content" android:layout_height="34dp"
          android:text="@string/chart_legend_humidity" android:textSize="11sp"
          android:paddingStart="10dp" android:paddingEnd="10dp"
          android:backgroundTint="#4FC3F7" android:layout_marginEnd="5dp"/>
        <Button android:id="@+id/chart_toggle_wind"
          style="@style/darkButton" android:layout_width="wrap_content" android:layout_height="34dp"
          android:text="@string/chart_legend_wind" android:textSize="11sp"
          android:paddingStart="10dp" android:paddingEnd="10dp"
          android:backgroundTint="#FFB74D" android:layout_marginEnd="5dp"/>
        <Button android:id="@+id/chart_toggle_pressure"
          style="@style/darkButton" android:layout_width="wrap_content" android:layout_height="34dp"
          android:text="@string/chart_legend_pressure" android:textSize="11sp"
          android:paddingStart="10dp" android:paddingEnd="10dp"
          android:backgroundTint="#81C784"/>
      </LinearLayout>
    </HorizontalScrollView>

    <!-- Value readout row -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="3dp">
      <TextView android:id="@+id/chart_hour_label"
        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:text="+00h" android:textSize="10sp" android:textStyle="italic"/>
      <TextView android:id="@+id/chart_val_temp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="—°" android:textSize="10sp" android:textColor="#FF5C8A" android:layout_marginEnd="7dp"/>
      <TextView android:id="@+id/chart_val_humidity"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="— %" android:textSize="10sp" android:textColor="#4FC3F7" android:layout_marginEnd="7dp"/>
      <TextView android:id="@+id/chart_val_wind"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="— m/s" android:textSize="10sp" android:textColor="#FFB74D" android:layout_marginEnd="7dp"/>
      <TextView android:id="@+id/chart_val_pressure"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="— hPa" android:textSize="10sp" android:textColor="#81C784"/>
    </LinearLayout>

    <!--
        ② chart_frame with an invisible SeekBar overlaid on top.
        The SeekBar (seekbar_chart_overlay) sits inside a FrameLayout so it
        covers the chart exactly. Its thumb is hidden (transparent drawable)
        and its track is transparent — it is purely a touch target.
        The receiver syncs it with seekBar bidirectionally via a shared
        updateHourCursor(int) helper.
    -->
    <FrameLayout
      android:id="@+id/chart_frame"
      android:layout_width="match_parent"
      android:layout_height="180dp"
      android:background="@drawable/image_view_bg"
      android:layout_marginBottom="4dp">

      <!-- The WeatherChartView is added programmatically into this FrameLayout -->

      <!-- Invisible overlay seekbar — full size, transparent, on top of chart -->
      <SeekBar
        android:id="@+id/seekbar_chart_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:max="167"
        android:progress="0"
        android:background="@null"
        android:progressDrawable="@null"
        android:thumb="@null"
        android:splitTrack="false"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:alpha="0.01"/>
      <!--
          alpha=0.01 (not 0) so the view receives touch events on older ATAK builds.
          The chart canvas is drawn below this transparent layer.
      -->
    </FrameLayout>

    <!-- Chart zoom + time range controls -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_marginBottom="3dp">

      <Button android:id="@+id/btn_chart_zoom_out"
        style="@style/darkButton"
        android:layout_width="36dp" android:layout_height="30dp"
        android:text="−" android:textSize="16sp"
        android:paddingStart="0dp" android:paddingEnd="0dp"
        android:layout_marginEnd="4dp"/>
      <Button android:id="@+id/btn_chart_zoom_in"
        style="@style/darkButton"
        android:layout_width="36dp" android:layout_height="30dp"
        android:text="+" android:textSize="16sp"
        android:paddingStart="0dp" android:paddingEnd="0dp"
        android:layout_marginEnd="8dp"/>

      <TextView android:id="@+id/chart_zoom_label"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="7d" android:textSize="10sp"
        android:textStyle="italic" android:alpha="0.7"
        android:layout_marginEnd="8dp"/>

      <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

      <Button android:id="@+id/btn_chart_range_24"
        style="@style/darkButton"
        android:layout_width="wrap_content" android:layout_height="28dp"
        android:text="24h" android:textSize="10sp"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:layout_marginEnd="3dp"/>
      <Button android:id="@+id/btn_chart_range_48"
        style="@style/darkButton"
        android:layout_width="wrap_content" android:layout_height="28dp"
        android:text="48h" android:textSize="10sp"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:layout_marginEnd="3dp"/>
      <Button android:id="@+id/btn_chart_range_72"
        style="@style/darkButton"
        android:layout_width="wrap_content" android:layout_height="28dp"
        android:text="3d" android:textSize="10sp"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:layout_marginEnd="3dp"/>
      <Button android:id="@+id/btn_chart_range_all"
        style="@style/darkButton"
        android:layout_width="wrap_content" android:layout_height="28dp"
        android:text="7d" android:textSize="10sp"
        android:paddingStart="8dp" android:paddingEnd="8dp"/>
    </LinearLayout>

    <TextView
      android:id="@+id/chart_status_text"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/wait"
      android:gravity="center"
      android:textSize="11sp"
      android:visibility="gone"/>

    <!-- ── Divider ─────────────────────────────────────────────────────────── -->
    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="#33FFFFFF"
      android:layout_marginBottom="4dp"/>

    <!-- ── 7-day forecast strip ───────────────────────────────────────────── -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/dailyForecast_title"
      android:textSize="12sp"
      android:textStyle="bold"
      android:layout_marginTop="2dp"/>

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content">
      <GridLayout android:id="@+id/daily_forecast_gridlayout"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:rowCount="1" android:columnCount="7"
        android:background="@drawable/image_view_bg">
        <TableLayout android:id="@+id/daily_forecast_tablelayout_1" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_date_textview_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="——" android:textSize="10sp" android:gravity="center_horizontal"/>
          <ImageView android:id="@+id/daily_forecast_weathercode_imageview_1" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/wc_00d" android:layout_gravity="center_horizontal" android:contentDescription="@string/weather_icon_desc"/>
          <TextView android:id="@+id/daily_forecast_temp_max_textview_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="H —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_temp_min_textview_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="L —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_weatherinfo_textview_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="10sp" android:gravity="center_horizontal" android:maxLines="2" android:ellipsize="end"/>
        </TableLayout>
        <TableLayout android:id="@+id/daily_forecast_tablelayout_2" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_date_textview_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="——" android:textSize="10sp" android:gravity="center_horizontal"/>
          <ImageView android:id="@+id/daily_forecast_weathercode_imageview_2" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/wc_00d" android:layout_gravity="center_horizontal" android:contentDescription="@string/weather_icon_desc"/>
          <TextView android:id="@+id/daily_forecast_temp_max_textview_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="H —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_temp_min_textview_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="L —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_weatherinfo_textview_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="10sp" android:gravity="center_horizontal" android:maxLines="2" android:ellipsize="end"/>
        </TableLayout>
        <TableLayout android:id="@+id/daily_forecast_tablelayout_3" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_date_textview_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="——" android:textSize="10sp" android:gravity="center_horizontal"/>
          <ImageView android:id="@+id/daily_forecast_weathercode_imageview_3" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/wc_00d" android:layout_gravity="center_horizontal" android:contentDescription="@string/weather_icon_desc"/>
          <TextView android:id="@+id/daily_forecast_temp_max_textview_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="H —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_temp_min_textview_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="L —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_weatherinfo_textview_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="10sp" android:gravity="center_horizontal" android:maxLines="2" android:ellipsize="end"/>
        </TableLayout>
        <TableLayout android:id="@+id/daily_forecast_tablelayout_4" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_date_textview_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="——" android:textSize="10sp" android:gravity="center_horizontal"/>
          <ImageView android:id="@+id/daily_forecast_weathercode_imageview_4" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/wc_00d" android:layout_gravity="center_horizontal" android:contentDescription="@string/weather_icon_desc"/>
          <TextView android:id="@+id/daily_forecast_temp_max_textview_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="H —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_temp_min_textview_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="L —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_weatherinfo_textview_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="10sp" android:gravity="center_horizontal" android:maxLines="2" android:ellipsize="end"/>
        </TableLayout>
        <TableLayout android:id="@+id/daily_forecast_tablelayout_5" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_date_textview_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="——" android:textSize="10sp" android:gravity="center_horizontal"/>
          <ImageView android:id="@+id/daily_forecast_weathercode_imageview_5" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/wc_00d" android:layout_gravity="center_horizontal" android:contentDescription="@string/weather_icon_desc"/>
          <TextView android:id="@+id/daily_forecast_temp_max_textview_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="H —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_temp_min_textview_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="L —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_weatherinfo_textview_5" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="10sp" android:gravity="center_horizontal" android:maxLines="2" android:ellipsize="end"/>
        </TableLayout>
        <TableLayout android:id="@+id/daily_forecast_tablelayout_6" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_date_textview_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="——" android:textSize="10sp" android:gravity="center_horizontal"/>
          <ImageView android:id="@+id/daily_forecast_weathercode_imageview_6" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/wc_00d" android:layout_gravity="center_horizontal" android:contentDescription="@string/weather_icon_desc"/>
          <TextView android:id="@+id/daily_forecast_temp_max_textview_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="H —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_temp_min_textview_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="L —" android:textSize="11sp" android:gravity="center_horizontal"/>
          <TextView android:id="@+id/daily_forecast_weatherinfo_textview_6" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="10sp" android:gravity="center_horizontal" android:maxLines="2" android:ellipsize="end"/>
        </TableLayout>
        <TableLayout android:id="@+id/daily_forecast_tablelayout_7" android:layout_width="100dp" android:layout_height="wrap_content" android:padding="4dp">
          <TextView android:id="@+id/daily_forecast_day_textview_7" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="—" android:textSize="11sp" android:textStyle="bold" android:gravity="center_horizontal"/>
