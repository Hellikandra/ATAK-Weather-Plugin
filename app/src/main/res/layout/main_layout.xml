<?xml version="1.0" encoding="utf-8"?>
<!--
    main_layout.xml

    IMPORTANT — Android <include> ID override rule:
    To override the root view's android:id via <include>, you MUST also
    specify android:layout_width and android:layout_height on the <include>
    tag, otherwise the override is silently ignored and TabHost cannot find
    the view to show/hide, causing all tabs to appear stacked at once.

    Tab order in receiver initTabs() must match order here:
      subTabWidget1 = Forecast
      subTabWidget2 = Wind
      subTabWidget3 = Overlay
-->
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

    <TabHost
      android:id="@+id/mainTabHost"
      android:layout_width="match_parent"
      android:layout_height="match_parent">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:orientation="vertical">

            <!-- Tab strip: MUST be android:id/tabs -->
            <TabWidget
              android:id="@android:id/tabs"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"/>

            <!-- Content area: MUST be android:id/tabcontent
                 TabHost sets all direct children GONE except the active tab.
                 The android:id on each <include> overrides the root view ID
                 ONLY when layout_width + layout_height are also specified. -->
            <FrameLayout
              android:id="@android:id/tabcontent"
              android:layout_width="match_parent"
              android:layout_height="0dp"
              android:layout_weight="1">

                <include
                  android:id="@+id/subTabWidget1"
                  layout="@layout/tab_current_weather"
                  android:layout_width="match_parent"
                  android:layout_height="match_parent"/>

                <include
                  android:id="@+id/subTabWidget2"
                  layout="@layout/tab_wind_profile"
                  android:layout_width="match_parent"
                  android:layout_height="match_parent"/>

                <include
                  android:id="@+id/subTabWidget3"
                  layout="@layout/tab_map_overlay"
                  android:layout_width="match_parent"
                  android:layout_height="match_parent"/>

            </FrameLayout>
        </LinearLayout>
    </TabHost>
</LinearLayout>
