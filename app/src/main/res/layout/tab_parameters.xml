<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_parameters.xml — Tab: Settings

    Sections:
      1. Weather Sources — source list with ON/OFF + Browse & Import + Scan Folder
      2. Radar Sources — radar source list with ON/OFF + Import + Scan Folder
      3. Auto-Refresh — interval spinner
      4. Theme — Dark / Light / NVG
      5. Mission Prep — download, progress, cache management
-->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/subTabWidget4"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 1: WEATHER SOURCES
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
      android:id="@+id/settings_section_sources"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginBottom="4dp">

      <TextView
        android:id="@+id/settings_header_sources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\u25BC Weather Sources"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/image_view_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

      <LinearLayout
        android:id="@+id/settings_content_sources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Source Manager (list with ON/OFF per source) -->
        <include layout="@layout/view_source_manager"
          android:id="@+id/source_manager_section"
          android:layout_width="match_parent"
          android:layout_height="wrap_content" />

        <!-- Active source status (kept for DDR binding) -->
        <TextView
          android:id="@+id/textview_parm_source_status"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text=""
          android:textSize="10sp"
          android:textStyle="italic"
          android:alpha="0.7"
          android:layout_marginBottom="2dp"
          android:visibility="gone"/>

        <TextView
          android:id="@+id/textview_parm_source_desc"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text=""
          android:textSize="9sp"
          android:alpha="0.6"
          android:layout_marginBottom="4dp"
          android:visibility="gone"/>

        <!-- Hidden spinner kept for backward compat (DDR wireParmSourceSpinner uses it) -->
        <Spinner
          android:id="@+id/spinner_parm_source"
          android:layout_width="0dp"
          android:layout_height="0dp"
          android:spinnerMode="dropdown"
          android:visibility="gone"/>

        <!-- Hidden flight-category badge (DDR still references it) -->
        <TextView
          android:id="@+id/badge_parm_flt_cat"
          android:layout_width="0dp"
          android:layout_height="0dp"
          android:visibility="gone"/>

        <!-- Hidden refresh button (DDR still references it) -->
        <Button
          android:id="@+id/btn_refresh_sources"
          android:layout_width="0dp"
          android:layout_height="0dp"
          android:visibility="gone"/>

      </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 2: RADAR SOURCES
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
      android:id="@+id/settings_section_radar_sources"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginBottom="4dp">

      <TextView
        android:id="@+id/settings_header_radar_sources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\u25B6 Radar Sources"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/image_view_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

      <LinearLayout
        android:id="@+id/settings_content_radar_sources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginBottom="4dp">

        <!-- Radar source list (items added programmatically with ON/OFF toggles) -->
        <LinearLayout
          android:id="@+id/radar_source_list"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:layout_marginBottom="6dp"/>

        <!-- Hidden spinner for backward compat -->
        <Spinner
          android:id="@+id/spinner_radar_source"
          android:layout_width="0dp"
          android:layout_height="0dp"
          android:spinnerMode="dropdown"
          android:visibility="gone"/>

        <!-- Action buttons row -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:layout_marginTop="4dp">

          <Button
            android:id="@+id/btn_import_tile_source"
            style="@style/darkButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Import Radar Source"
            android:textSize="10sp"
            android:layout_marginEnd="4dp"/>

          <Button
            android:id="@+id/btn_scan_radar_folder"
            style="@style/darkButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Scan Folder"
            android:textSize="10sp"/>
        </LinearLayout>

      </LinearLayout>
    </LinearLayout>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#30363d" android:layout_marginBottom="4dp"/>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 3: AUTO-REFRESH
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
      android:id="@+id/settings_section_auto_refresh"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginBottom="4dp">

      <TextView
        android:id="@+id/settings_header_auto_refresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\u25B6 Auto-Refresh"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/image_view_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

      <LinearLayout
        android:id="@+id/settings_content_auto_refresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginBottom="4dp">

        <Spinner
          android:id="@+id/spinner_auto_refresh"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:minHeight="44dp"
          android:spinnerMode="dropdown"/>
      </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 4: THEME
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
      android:id="@+id/settings_section_theme"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginBottom="4dp">

      <TextView
        android:id="@+id/settings_header_theme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\u25B6 Theme"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/image_view_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

      <LinearLayout
        android:id="@+id/settings_content_theme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginBottom="4dp">

        <Spinner
          android:id="@+id/spinner_theme"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:minHeight="44dp"
          android:spinnerMode="dropdown"/>
      </LinearLayout>
    </LinearLayout>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
      android:background="#30363d" android:layout_marginBottom="4dp"/>

    <!-- ══════════════════════════════════════════════════════════════════
         SECTION 5: MISSION PREP
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
      android:id="@+id/settings_section_mission_prep"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:layout_marginBottom="4dp">

      <TextView
        android:id="@+id/settings_header_mission_prep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\u25B6 Mission Prep"
        android:textSize="13sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/image_view_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

      <LinearLayout
        android:id="@+id/settings_content_mission_prep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:layout_marginBottom="4dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/mission_prep_desc"
          android:textSize="10sp"
          android:alpha="0.7"
          android:layout_marginBottom="4dp"/>

        <Button
          android:id="@+id/btn_mission_prep"
          style="@style/darkButton"
          android:layout_width="match_parent"
          android:layout_height="44dp"
          android:text="@string/mission_prep_download"
          android:textSize="11sp"
          android:layout_marginBottom="4dp"/>

        <ProgressBar
          android:id="@+id/mission_prep_progress"
          style="?android:attr/progressBarStyleHorizontal"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:max="100"
          android:progress="0"
          android:layout_marginBottom="2dp"
          android:visibility="gone"/>

        <TextView
          android:id="@+id/mission_prep_status"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text=""
          android:textSize="10sp"
          android:alpha="0.7"
          android:layout_marginBottom="4dp"
          android:visibility="gone"/>

        <!-- Cache Info + Clear -->
        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:layout_marginBottom="4dp">

          <TextView
            android:id="@+id/cache_info_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cache: 0 MB"
            android:textSize="10sp"
            android:alpha="0.7"/>

          <Button
            android:id="@+id/btn_clear_cache"
            style="@style/darkButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_clear_cache_label"
            android:textSize="10sp"
            android:layout_marginStart="8dp"/>
        </LinearLayout>

      </LinearLayout>
    </LinearLayout>

  </LinearLayout>
</ScrollView>
