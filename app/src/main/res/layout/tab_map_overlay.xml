<?xml version="1.0" encoding="utf-8"?>
<!--
    tab_map_overlay.xml — Tab 3: Map / Marker controls

    Feature: "Drop Weather Marker" is now a two-step flow:
      1. User taps the button → panel collapses, a hint banner appears,
         the button becomes "Cancel Pick" (red).
      2. User taps a point on the live map → weather is fetched for that
         point, the marker is placed, the panel reopens.

    The picking_hint banner (hidden by default) is shown by
    WeatherDropDownReceiver while MapPointPicker is active.
-->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/subTabWidget3"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- ── Section title ─────────────────────────────────────────── -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_section_title"
      android:textSize="13sp"
      android:textStyle="bold"
      android:layout_marginBottom="4dp"/>

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_pick_description"
      android:textSize="11sp"
      android:layout_marginBottom="12dp"/>

    <!-- ── Pick-mode hint banner (hidden until pick is active) ───── -->
    <TextView
      android:id="@+id/textview_pick_hint"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_pick_hint"
      android:textSize="11sp"
      android:textStyle="bold"
      android:textColor="#FFFFA500"
      android:background="#33FFA500"
      android:padding="8dp"
      android:layout_marginBottom="8dp"
      android:visibility="gone"/>

    <!-- ── Drop marker (primary action) ─────────────────────────── -->
    <Button
      android:id="@+id/btn_drop_weather_marker"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:text="@string/map_btn_pick_and_drop"
      android:textSize="12sp"
      android:layout_marginBottom="8dp"/>

    <!-- ── Share current marker over TAK network ─────────────────── -->
    <Button
      android:id="@+id/btn_share_marker"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:text="@string/map_btn_share_marker"
      android:textSize="12sp"
      android:layout_marginBottom="8dp"/>

    <!-- ── Remove all weather markers ────────────────────────────── -->
    <Button
      android:id="@+id/btn_remove_all_markers"
      style="@style/darkButton"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:text="@string/map_btn_remove_markers"
      android:textSize="12sp"
      android:layout_marginBottom="16dp"/>

    <!-- ── Divider ───────────────────────────────────────────────── -->
    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:background="#33FFFFFF"
      android:layout_marginBottom="12dp"/>

    <!-- ── Status ────────────────────────────────────────────────── -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_status_label"
      android:textSize="11sp"
      android:textStyle="bold"
      android:layout_marginBottom="4dp"/>

    <TextView
      android:id="@+id/textview_marker_status"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/map_marker_none_placed"
      android:textSize="11sp"
      android:fontFamily="monospace"/>

  </LinearLayout>
</ScrollView>
